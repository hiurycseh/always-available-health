            ["❤️", "Humanizado", "Atendimento respeitoso e acolhedor."],
            ["🔒", "Privacidade", "Sigilo garantido em todas as etapas."],
            ["🌍", "Cobertura Nacional", "Disponível em todo o Brasil."],
            ["✓", "Suporte Integral", "Acompanhamento completo e personalizado."],
          ].map(([icon, title, desc]) => (
