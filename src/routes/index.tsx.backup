      </nav>

      <section className="hero" style={{ backgroundImage: `url(${heroBg})` }}>
        <div className="hero-overlay" />
        <div className="hero-content">
          <div className="hero-tags">
            <span className="hero-tag">♡ Atendimento Humanizado</span>
